{
  "name": "esp_wifi_config",
  "version": "0.0.2",
  "description": "WiFi configuration library for ESP-IDF with multi-network support, auto-reconnect, SoftAP captive portal, BLE provisioning, and REST API",
  "keywords": "wifi, esp32, esp-idf, captive-portal, softap, ble, provisioning, improv, configuration",
  "repository": {
    "type": "git",
    "url": "https://github.com/thorrak/esp_wifi_config.git"
  },
  "authors": [
    {
      "name": "Thorrak",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "homepage": "https://configwifi.com",
  "frameworks": "espidf",
  "platforms": "espressif32",
  "headers": "esp_wifi_config.h",
  "build": {
    "srcDir": "src",
    "includeDir": "include"
  },
  "export": {
    "include": [
      "include/*",
      "src/*",
      "frontend/dist/*",
      "CMakeLists.txt",
      "Kconfig.projbuild",
      "idf_component.yml",
      "LICENSE",
      "README.md"
    ]
  }
}
